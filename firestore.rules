rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return request.auth != null && request.auth.token.email == "graficadfuturo@gmail.com";
    }

    match /site/config {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /portals/{clientId} {
      allow read, write: if true;
    }

    match /test/connection {
      allow read: if true;
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
